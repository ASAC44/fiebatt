# ── frontend (Next.js) ────────────────────────────────────────────────
# Backend dev target used by the Next /api and /media rewrites.
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"
# When true, signup is temporarily blocked and auth pages show a credits notice.
NEXT_PUBLIC_AI_CREDITS_EXHAUSTED="false"

# ── backend (FastAPI) ────────────────────────────────────────────────
# First-party auth. This one is SECRET — never ship to the browser.
AUTH_JWT_SECRET="change-me"
AUTH_JWT_EXPIRES_MINUTES="10080"
# Public backend origin used as the OAuth issuer and MCP resource origin.
PUBLIC_API_URL="http://localhost:8000"
OAUTH_ACCESS_TOKEN_MINUTES="60"
OAUTH_REFRESH_TOKEN_DAYS="30"
# Base64url encoding of 32 random bytes. Keep stable or saved provider keys cannot be decrypted.
CREDENTIAL_ENCRYPTION_KEY=""
UPLOAD_INTENT_EXPIRY_SECONDS="900"
MAX_UPLOAD_BYTES="524288000"

# Gemini (optional, only if you're hitting the live service).
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# Mesh API model gateway (optional). When set, text/tool planning routes through Mesh.
MESH_API_KEY=""
MESH_API_BASE_URL="https://api.meshapi.ai/v1"
MESH_MODEL="deepseek/deepseek-v3.2"
MESH_VIDEO_MODEL="google/veo-3"
MESH_VIDEO_ENDPOINT="/video/generations"
# Leave true for stubbed local dev. Flip to false for the real demo path.
USE_AI_STUBS="true"
ADAPTIVE_EDIT_PLANNING="false"
GLOBAL_EDIT_PLANNING="false"
# Emergency-only: keep false so continuity hard-fails cannot be accepted.
ALLOW_HARD_FAILED_ACCEPTANCE="false"

# Live video provider:
#   auto        -> Wan for uploaded-footage edits; Veo for generated shots
#   wan         -> DashScope Wan source-video editing (requires DASHSCOPE_API_KEY)
#   veo         -> Google Veo via Gemini API (requires GEMINI_API_KEY)
#   happyhorse  -> DashScope HappyHorse fallback (requires DASHSCOPE_API_KEY)
#   meshapi_veo -> Mesh API video gateway (requires MESH_API_KEY)
VIDEO_GEN_PROVIDER="auto"
VEO_MODEL="veo-3.1-fast-generate-preview"
VIDEO_GENERATION_TIMEOUT=1800

# Public URL of this deployment (used for cors, links, etc).
APP_URL="http://localhost:3001"

# ── vultr object storage (S3-compatible) ─────────────────────────────
# media files (uploads, keyframes, exports) live here. the backend uses
# boto3 against this endpoint. do NOT commit the secret key.
VULTR_S3_ENDPOINT="https://ewr1.vultrobjects.com"
VULTR_S3_REGION="ewr1"
VULTR_S3_BUCKET="fiebatt"
VULTR_S3_ACCESS_KEY=""
VULTR_S3_SECRET_KEY=""
# how media urls are served to the frontend:
#   presigned  → backend mints short-lived GET urls, bucket stays private (recommended)
#   public     → objects are public-read, urls are raw endpoint/bucket/key
MEDIA_URL_MODE="presigned"

# ── vultr managed postgres ──────────────────────────────────────────
# replaces the local sqlite file. must use asyncpg dsn for fastapi.
DATABASE_URL="postgresql+asyncpg://vultradmin:PASSWORD@fiebatt-db.vultrdb.com:16751/fiebatt?ssl=require"

# ── vision worker / ai observability ───────────────────────────────
# Local backend development expects localhost:8001. Docker Compose defaults to
# http://vision-worker:8001 unless you override it here or in your shell.
# For the judge/demo path, point this at the hosted vision worker public URL.
VISION_WORKER_URL="http://localhost:8001"
