# web (Next.js)
# API target used by the Next /api and /media rewrites.
NEXT_PUBLIC_API_URL="http://localhost:8000"
# When true, signup is temporarily blocked and auth pages show a credits notice.
NEXT_PUBLIC_AI_CREDITS_EXHAUSTED="false"

# api (FastAPI)
APP_ENV="development"
# First-party auth. This one is SECRET — never ship to the browser.
AUTH_JWT_SECRET="change-me"
AUTH_JWT_EXPIRES_MINUTES="10080"
AUTH_COOKIE_SECURE="false"
# Public API origin used as the OAuth issuer and MCP resource origin.
PUBLIC_API_URL="http://localhost:8000"
OAUTH_ACCESS_TOKEN_MINUTES="60"
OAUTH_REFRESH_TOKEN_DAYS="30"
UPLOAD_INTENT_EXPIRY_SECONDS="900"
MAX_UPLOAD_BYTES="524288000"

# Platform-managed service keys. Never expose these to the frontend.
GEMINI_API_KEY=""
DASHSCOPE_API_KEY=""
ELEVENLABS_API_KEY=""
# Mesh API model gateway (optional). When set, text/tool planning routes through Mesh.
MESH_API_KEY=""
MESH_API_BASE_URL="https://api.meshapi.ai/v1"
MESH_MODEL="deepseek/deepseek-v3.2"
MESH_VIDEO_MODEL="google/veo-3"
MESH_VIDEO_ENDPOINT="/video/generations"
# Leave true for local development. Production startup requires false.
USE_AI_STUBS="true"
ADAPTIVE_EDIT_PLANNING="true"
GLOBAL_EDIT_PLANNING="false"
# Emergency-only: keep false so continuity hard-fails cannot be accepted.
ALLOW_HARD_FAILED_ACCEPTANCE="false"

# Server-side video routing. Keep `auto` unless an operator needs to pin a route.
#   auto        -> Wan for uploaded-footage edits; Veo for generated shots
#   wan         -> DashScope Wan source-video editing (requires DASHSCOPE_API_KEY)
#   veo         -> Google Veo via Gemini API (requires GEMINI_API_KEY)
#   happyhorse  -> DashScope HappyHorse fallback (requires DASHSCOPE_API_KEY)
#   meshapi_veo -> Mesh API video gateway (requires MESH_API_KEY)
VIDEO_GEN_PROVIDER="auto"
VEO_MODEL="veo-3.1-fast-generate-preview"
VIDEO_GENERATION_TIMEOUT=1800

# Public frontend origin (used for CORS and OAuth links).
APP_URL="http://localhost:3001"

# ── object storage ───────────────────────────────────────────────────
# Setting S3_BUCKET enables object storage. Leave it empty to use local media.
# Standard AWS credentials are optional when the runtime provides an IAM role.
S3_BUCKET=""
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
# Set only when using an S3-compatible endpoint instead of Amazon S3.
S3_ENDPOINT_URL=""
# how media URLs are served to the web app:
#   presigned  → API mints short-lived GET URLs, bucket stays private (recommended)
#   public     → objects are public-read, urls are raw endpoint/bucket/key
MEDIA_URL_MODE="presigned"

# ── database ─────────────────────────────────────────────────────────
# Leave unset for local SQLite, or use an asyncpg PostgreSQL DSN.
# DATABASE_URL="postgresql+asyncpg://fiebatt:password@localhost:5432/fiebatt"

# ── vision worker / ai observability ───────────────────────────────
# Local API development expects localhost:8001. Docker Compose defaults to
# http://vision-worker:8001 unless you override it here or in your shell.
# For a hosted worker, point this at its public URL. Hugging Face ZeroGPU
# Spaces provide segmentation only; configure one separately below.
VISION_WORKER_URL="http://localhost:8001"
# Optional single-frame SAM endpoint, such as a ZeroGPU Gradio Space.
SAM_SEGMENTATION_URL=""
